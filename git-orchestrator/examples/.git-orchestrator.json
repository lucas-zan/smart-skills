{
  "policy": {
    "defaults": {
      "base_branch_strategy": "current-branch",
      "feature_branch_prefix": "agent",
      "share_branch_prefix": "share"
    },
    "verify": {
      "command": "cargo fmt --check && cargo clippy --all-targets --all-features -- -D warnings && cargo test"
    },
    "evidence": {
      "enforce_before_commit": true,
      "require_requirements": true,
      "require_design": true,
      "require_tests": true,
      "requirement_globs": [
        "docs/requirements/**/*.md",
        "docs/prd/**/*.md",
        "docs/**/*requirement*.md"
      ],
      "design_globs": [
        "docs/design/**/*.md",
        "docs/architecture/**/*.md",
        "docs/**/*design*.md"
      ],
      "test_globs": [
        "tests/**/*",
        "**/*_test.py",
        "**/*_test.rs",
        "**/*.spec.ts",
        "**/*.test.ts",
        "**/*.spec.js",
        "**/*.test.js",
        "**/*.spec.tsx",
        "**/*.test.tsx"
      ]
    },
    "share_and_land": {
      "allow_direct": true,
      "protected_branches": [
        "test",
        "release"
      ],
      "protected_branch_mode": "require-pull-request",
      "reverify_on_base_change": true,
      "max_reverify_attempts": 3
    }
  },
  "workflows": {
    "deploy.yml": {
      "default_ref": "main",
      "required_inputs": [
        "environment"
      ],
      "allowed_inputs": [
        "environment",
        "service",
        "image_tag",
        "dry_run",
        "release_note"
      ],
      "default_inputs": {
        "service": "web",
        "dry_run": "false"
      },
      "presets": {
        "staging": {
          "environment": "staging"
        },
        "prod": {
          "environment": "prod",
          "dry_run": "false"
        }
      }
    }
  }
}
